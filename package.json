{
  "name": "friday",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "worktrees": "bun run src/worktree/cli.ts list",
    "cleanup": "bun run src/worktree/cli.ts reap",
    "browser-login": "bun bin/browser-login.ts",
    "voice": "bun run src/voice/cli.ts start",
    "voice:toggle": "bun run src/voice/cli.ts toggle",
    "voice:status": "bun run src/voice/cli.ts status",
    "voice:stop": "bun run src/voice/cli.ts stop"
  },
  "dependencies": {
    "@playwright/mcp": "^0.0.70",
    "@slack/bolt": "^4.3.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "typescript": "^5.8.0"
  }
}
