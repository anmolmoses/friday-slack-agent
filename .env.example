# =====================================================================
# Slack App (Socket Mode)
# =====================================================================
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=
# Your Slack workspace subdomain (the part before .slack.com).
# Used to construct message permalinks in dispatch followups.
SLACK_WORKSPACE_DOMAIN=your-workspace
# Optional — user token (xoxp-) so Friday can post AS the owner instead
# of as the bot for the standup workflow. Leave empty to post as the bot.
# SLACK_USER_TOKEN=xoxp-...

# =====================================================================
# Claude Code
# =====================================================================
CLAUDE_MAX_TURNS=25
CLAUDE_TIMEOUT_MS=300000
CLAUDE_PERMISSION_MODE=bypassPermissions

# =====================================================================
# Owner — the Slack user Friday primarily serves
# =====================================================================
# Find your ID by clicking your Slack profile -> More -> Copy member ID.
# Friday gates control commands (`!build`, `!reset`, etc.) to this user.
FRIDAY_OWNER_USER_ID=U00000000

# =====================================================================
# Routing — comma-separated lists of Slack IDs
# =====================================================================
# PR URLs from these users in PR-review channels auto-trigger review.
FRIDAY_TRUSTED_USER_IDS=U00000000

# Friday will never auto-reply to these (e.g. execs you only want to
# "react 👀" to, never engage with). Empty list is fine.
FRIDAY_NO_REPLY_USER_IDS=

# Sandbox channels — added to every routing scope so you can exercise
# PR review / bug triage / catchup in one place.
FRIDAY_TEST_CHANNELS=

# Channels where Friday auto-replies to every human message (no @mention
# needed). Use sparingly — sandbox channels only.
FRIDAY_ALWAYS_REPLY_CHANNELS=

# Channels where a GitHub PR URL from a trusted user auto-triggers review.
FRIDAY_PR_REVIEW_CHANNELS=

# Channels where bug-report-shaped messages auto-trigger triage.
FRIDAY_BUG_TRIAGE_CHANNELS=

# Optional — user ID of a bug-report bot (e.g. a forms integration). Posts
# from this user in bug-triage channels always trigger triage.
FRIDAY_BUG_REPORT_BOT_USER_ID=

# =====================================================================
# Standup workflow (optional — leave empty to disable)
# =====================================================================
# Channel where Friday opens the daily kickoff thread and asks the owner
# what they worked on. Standup is only enabled when all three are set.
FRIDAY_STANDUP_KICKOFF_CHANNEL=
# Channel where the final approved standup post is dropped (in the
# focus-bot's daily thread).
FRIDAY_STANDUP_TARGET_CHANNEL=
# Bot ID (B...) of the focus bot whose daily post Friday replies under.
FRIDAY_STANDUP_FOCUS_BOT_ID=

# =====================================================================
# Repos (JSON array) — point each path at a clone on YOUR machine
# =====================================================================
REPOS=[{"name":"example-backend","path":"~/Projects/example-backend","defaultBase":"origin/main"},{"name":"example-frontend","path":"~/Projects/example-frontend","defaultBase":"origin/main"}]

# =====================================================================
# Session
# =====================================================================
SESSION_STALE_TIMEOUT_MS=86400000
SESSION_CLEANUP_INTERVAL_MS=900000

# =====================================================================
# Optional — Redis (in-memory store if not set)
# =====================================================================
# REDIS_URL=redis://localhost:6379

# =====================================================================
# Optional — MongoDB read-only access via mongodb-mcp-server --readOnly
# =====================================================================
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/db?retryWrites=true&w=majority
