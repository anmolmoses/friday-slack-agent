# Slack App (Socket Mode)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=...

# Claude Code
CLAUDE_MAX_TURNS=25
CLAUDE_TIMEOUT_MS=300000
CLAUDE_PERMISSION_MODE=bypassPermissions

# Repos (JSON array) — point each path at a clone on YOUR machine
REPOS=[{"name":"example-backend","path":"~/Projects/example-backend","defaultBase":"origin/main"},{"name":"example-frontend","path":"~/Projects/example-frontend","defaultBase":"origin/main"}]

# HTTP server / dashboard (chat UI, /live dashboard, /api, /events) — default 3000
HTTP_PORT=3000

# Session
SESSION_STALE_TIMEOUT_MS=86400000
SESSION_CLEANUP_INTERVAL_MS=900000

# Voice route (optional)
FRIDAY_VOICE=shimmer
FRIDAY_VOICE_NOISE_REDUCTION=far_field
FRIDAY_VOICE_VAD_THRESHOLD=0.12
FRIDAY_VOICE_VAD_SILENCE_MS=450
FRIDAY_VOICE_LOCAL_VAD=true
FRIDAY_VOICE_LOCAL_VAD_MIN_LEVEL=0.055
FRIDAY_VOICE_LOCAL_VAD_NOISE_RATIO=2.6
FRIDAY_VOICE_LOCAL_VAD_START_FRAMES=8
FRIDAY_VOICE_LOCAL_VAD_END_MS=350
FRIDAY_VOICE_LOCAL_VAD_MIN_OPEN_MS=500
FRIDAY_VOICE_LOCAL_VAD_END_RATIO=0.9
FRIDAY_VOICE_LOCAL_VAD_MAX_OPEN_MS=10000
FRIDAY_VOICE_ECHO_SUPPRESSION_MS=2500
FRIDAY_VOICE_PLAYER=auto
FRIDAY_VOICE_PLAYBACK_PREBUFFER_MS=120
FRIDAY_VOICE_PLAYBACK_GAIN=1
# Audio length caps (Realtime max_output_tokens). Keep high so spoken answers are not clipped mid-sentence.
FRIDAY_VOICE_MAX_OUTPUT_TOKENS=1024
FRIDAY_VOICE_SHORT_REPLY_TOKENS=320
FRIDAY_VOICE_MAX_TOOL_CALL_TOKENS=512
FRIDAY_VOICE_TOOL_AUDIO_HOLD_MS=1200
# Canned/preloaded acks. With FRIDAY_VOICE_AI_DRIVEN=true the model narrates results itself, so keep these off.
FRIDAY_VOICE_TOOL_LOCAL_ACK=false
FRIDAY_VOICE_TOOL_LOCAL_ACK_TEXT=On it.
FRIDAY_VOICE_TOOL_LOCAL_ACK_MODEL=tts-1
FRIDAY_VOICE_TOOL_PROGRESS_ACK=false
FRIDAY_VOICE_TOOL_PROGRESS_ACK_TEXT=Still working through it.
FRIDAY_VOICE_TOOL_PROGRESS_ACK_AFTER_MS=4500
# AI-driven: model decides every action and narrates every result (no regex actions, no canned speech).
FRIDAY_VOICE_AI_DRIVEN=true
FRIDAY_VOICE_ACTION_CLASSIFY_WAIT_MS=250
# Multi-step autonomy budget. Vision (screen_see) is slow, so give real headroom to finish UI tasks.
FRIDAY_VOICE_TOOL_LOOP_MAX_CALLS=24
FRIDAY_VOICE_TOOL_LOOP_MAX_MS=120000
FRIDAY_VOICE_RUN_SHELL_FAST_WAIT_MS=400
FRIDAY_VOICE_WEB_FETCH_TIMEOUT_MS=3500
FRIDAY_VOICE_BROWSER_SCREENSHOT_TIMEOUT_MS=6500
FRIDAY_VOICE_REALTIME_IMAGE_MAX_PX=768
FRIDAY_VOICE_REALTIME_IMAGE_FAST_MAX_PX=640
FRIDAY_VOICE_REALTIME_IMAGE_FORMAT=jpeg
FRIDAY_VOICE_REALTIME_IMAGE_QUALITY=70
FRIDAY_VOICE_REALTIME_IMAGE_FAST_QUALITY=60
FRIDAY_VOICE_DISPATCH_LAUNCH_TIMEOUT_MS=3000
FRIDAY_VOICE_AUTO_IDLE_AFTER_TURN=false
FRIDAY_VOICE_CAMERA=false
FRIDAY_VOICE_CAMERA_INDEX=0
FRIDAY_VOICE_CAMERA_WIDTH=1280
FRIDAY_VOICE_CAMERA_HEIGHT=720
FRIDAY_VOICE_CAMERA_WARMUP_MS=1500
FRIDAY_VOICE_CAMERA_AUTO_RECOGNIZE=false
FRIDAY_VOICE_CAMERA_AUTO_INTERVAL_MS=8000
FRIDAY_VOICE_CAMERA_AUTO_MIN_CONFIDENCE=0.78
FRIDAY_VOICE_SPEAKER_RECOGNITION=false
FRIDAY_VOICE_SPEAKER_MIN_SAMPLE_MS=900
FRIDAY_VOICE_SPEAKER_MAX_SAMPLE_MS=5000
FRIDAY_VOICE_SPEAKER_MIN_CONFIDENCE=0.72
FRIDAY_VOICE_SPEAKER_PROACTIVE_IDENTIFY=false
FRIDAY_VOICE_SPEAKER_NOVELTY_COOLDOWN_MS=60000
FRIDAY_VOICE_BACKGROUND_TRANSCRIPTION=true
FRIDAY_VOICE_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
FRIDAY_VOICE_TRANSCRIPTION_LANGUAGE=en
# Claude vision click-grounding (find_and_click). Needs ANTHROPIC_API_KEY set above; without it find_and_click is disabled.
FRIDAY_VOICE_VISION_MODEL=claude-sonnet-4-6
# FRIDAY_VOICE_TRANSCRIPTION_PROMPT=Names: Anmol, FRIDAY. Apps: Slack, Chrome.
FRIDAY_VOICE_INTERRUPTION=false
FRIDAY_VOICE_INTERRUPT_MIN_LEVEL=0.75
FRIDAY_VOICE_INTERRUPT_FRAMES=40
FRIDAY_VOICE_INTERRUPT_BUFFER_MS=650
FRIDAY_VOICE_INTERRUPT_COOLDOWN_MS=8000
FRIDAY_VOICE_INTERRUPT_MIN_ASSISTANT_MS=1500
FRIDAY_VOICE_INTERRUPT_MAX_PER_RESPONSE=1

# Engram memory (optional)
ENGRAM_RECALL=0
ENGRAM_CAPTURE=0

# Redis (optional — in-memory if not set)
# REDIS_URL=redis://localhost:6379

# MongoDB (read-only access for Friday via mongodb-mcp-server --readOnly)
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/db?retryWrites=true&w=majority
