# Slack App (Socket Mode)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=...

# Claude Code
CLAUDE_MAX_TURNS=25
CLAUDE_TIMEOUT_MS=300000
CLAUDE_PERMISSION_MODE=bypassPermissions

# Repos (JSON array) — point each path at a clone on YOUR machine
REPOS=[{"name":"example-backend","path":"~/Projects/example-backend","defaultBase":"origin/main"},{"name":"example-frontend","path":"~/Projects/example-frontend","defaultBase":"origin/main"}]

# Session
SESSION_STALE_TIMEOUT_MS=86400000
SESSION_CLEANUP_INTERVAL_MS=900000

# Voice route (optional)
FRIDAY_VOICE=shimmer
FRIDAY_VOICE_NOISE_REDUCTION=far_field
FRIDAY_VOICE_CAMERA=false
FRIDAY_VOICE_CAMERA_INDEX=0
FRIDAY_VOICE_CAMERA_WIDTH=1280
FRIDAY_VOICE_CAMERA_HEIGHT=720
FRIDAY_VOICE_CAMERA_WARMUP_MS=1500
FRIDAY_VOICE_BACKGROUND_TRANSCRIPTION=true
FRIDAY_VOICE_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
FRIDAY_VOICE_TRANSCRIPTION_LANGUAGE=en
# FRIDAY_VOICE_TRANSCRIPTION_PROMPT=Names: Anmol, FRIDAY. Apps: Slack, Spotify, Chrome.
FRIDAY_VOICE_INTERRUPTION=false
FRIDAY_VOICE_INTERRUPT_MIN_LEVEL=0.75
FRIDAY_VOICE_INTERRUPT_FRAMES=40
FRIDAY_VOICE_INTERRUPT_BUFFER_MS=650
FRIDAY_VOICE_INTERRUPT_COOLDOWN_MS=8000
FRIDAY_VOICE_INTERRUPT_MIN_ASSISTANT_MS=1500
FRIDAY_VOICE_INTERRUPT_MAX_PER_RESPONSE=1

# Engram memory (optional)
ENGRAM_RECALL=0
ENGRAM_CAPTURE=0

# Redis (optional — in-memory if not set)
# REDIS_URL=redis://localhost:6379

# MongoDB (read-only access for Friday via mongodb-mcp-server --readOnly)
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/db?retryWrites=true&w=majority
